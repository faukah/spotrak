{
  "mcpServers": {
    "chrome-devtools": {
      "command": "bunx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--browser-url",
        "http://127.0.0.1:9222",
        "--executablePath",
        "/run/current-system/sw/bin/helium"
      ]
    }
  }
}
