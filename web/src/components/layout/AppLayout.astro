---
import { ClientRouter } from 'astro:transitions';
// oxlint-disable-next-line import/no-unassigned-import -- Astro CSS entrypoint side-effect import.
import '../../styles/global.css';
import AuthStatus from './AuthStatus.svelte';
import AuthGate from '../auth/AuthGate.svelte';
import SearchBox from '../search/SearchBox.svelte';
import ThemeScript from './ThemeScript.astro';
import StatsRangeScript from './StatsRangeScript.astro';
import ThemeToggle from './ThemeToggle.svelte';
import MobileMenu from './MobileMenu.svelte';

interface Props {
  title?: string;
}

const { title = 'Spotrak' } = Astro.props;
const pathname = Astro.url.pathname;
const nav = [
  ['Overview', '/'],
  ['Stats', '/stats'],
  ['History', '/history'],
  ['Tracks', '/top/tracks'],
  ['Artists', '/top/artists'],
  ['Albums', '/top/albums'],
  ['Imports', '/imports'],
  ['Settings', '/settings'],
  ['Admin', '/admin'],
];

function isActive(href: string) {
  return href === '/' ? pathname === '/' : pathname.startsWith(href);
}

const navItems = nav.map(([label, href]) => ({ label, href, active: isActive(href) }));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="oklch(0.94 0.01 85)" />
    <ThemeScript />
    <StatsRangeScript />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <AuthGate client:load />
    <header class="site-header">
      <a class="brand" href="/" aria-label="Spotrak overview" data-astro-prefetch="hover">
        <span class="brand-mark">ST</span>
        <span>Spotrak</span>
      </a>
      <div class="desktop-search">
        <SearchBox id="desktop-library-search" name="desktop-library-search" client:load />
      </div>
      <nav class="shell-nav desktop-nav" aria-label="Main navigation">
        {navItems.map((item) => <a href={item.href} aria-current={item.active ? 'page' : undefined} data-astro-prefetch="hover">{item.label}</a>)}
      </nav>
      <div class="site-controls desktop-controls">
        <ThemeToggle client:load />
        <AuthStatus client:load />
      </div>
      <MobileMenu navItems={navItems} includeSearch includeAuth menuId="site-mobile-menu" client:media="(max-width: 760px)" />
    </header>
    <main class="page">
      <slot />
    </main>
  </body>
</html>
