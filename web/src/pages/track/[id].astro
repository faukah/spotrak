---
import AppLayout from '../../components/layout/AppLayout.astro';
import CatalogDetailPage from '../../components/pages/CatalogDetailPage.astro';
import { serverApiFetch } from '../../lib/api/server';
import type { TrackDetail } from '../../lib/api/types';
const { id = '' } = Astro.params;
const transitionName = Astro.url.searchParams.get('vt') ?? undefined;
const initialDetail = await serverApiFetch<TrackDetail>(Astro.request, `/tracks/${id}`);
---

<AppLayout title="Track · Spotrak">
  <CatalogDetailPage kind="track" {id} {initialDetail} {transitionName} />
</AppLayout>
