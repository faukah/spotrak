---
import AppLayout from '../../components/layout/AppLayout.astro';
import CatalogDetailPage from '../../components/pages/CatalogDetailPage.astro';
import { serverApiFetch } from '../../lib/api/server';
import type { ArtistDetail } from '../../lib/api/types';
const { id = '' } = Astro.params;
const transitionName = Astro.url.searchParams.get('vt') ?? undefined;
const initialDetail = await serverApiFetch<ArtistDetail>(Astro.request, `/artists/${id}`);
---

<AppLayout title="Artist · Spotrak">
  <CatalogDetailPage kind="artist" {id} {initialDetail} {transitionName} />
</AppLayout>
