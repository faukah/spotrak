---
import AppLayout from '../components/layout/AppLayout.astro';
import OverviewPage from '../components/pages/OverviewPage.astro';
import { serverApiFetch } from '../lib/api/server';
import type { OverviewStatsResponse } from '../lib/api/types';
import { overviewQuery, statsRangeFromCookie } from '../lib/stats-page';
import { STATS_RANGE_COOKIE_NAME } from '../lib/stores/stats-range';

const rangeCookie = Astro.cookies.get(STATS_RANGE_COOKIE_NAME)?.value ?? null;
const initialRange = statsRangeFromCookie(rangeCookie);
const initialOverview = await serverApiFetch<OverviewStatsResponse>(
  Astro.request,
  `/stats/overview?${overviewQuery(initialRange)}`,
);
---

<AppLayout title="Overview · Spotrak">
  <OverviewPage {initialOverview} />
</AppLayout>
