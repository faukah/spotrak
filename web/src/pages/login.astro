---
import AppLayout from '../components/layout/AppLayout.astro';
import LoginCard from '../components/cards/LoginCard.svelte';
const next = Astro.url.searchParams.get('next');
const message = next ? 'Your session expired or authentication is required.' : 'Sign in to continue.';
---

<AppLayout title="Login · Spotrak">
  <section class="login-page">
    <div class="page-title">
      <h1>Sign in</h1>
    </div>
    <LoginCard message={message} next={next} />
  </section>
</AppLayout>

<style>
  .login-page {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 34rem);
    gap: 1rem;
    align-items: end;
    min-height: 42vh;
  }

  @media (max-width: 820px) {
    .login-page {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
