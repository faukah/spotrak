---
import HistoryPage from '../../../components/pages/HistoryPage.astro';
import PublicPageShell from '../../../components/pages/PublicPageShell.astro';
import { publicShareContext } from '../../../lib/public-share';

const { token = '' } = Astro.params;
const { apiPrefix, pagePrefix, valid } = await publicShareContext(Astro.request, token);
---

<PublicPageShell title="Shared history · Spotrak" {token} {valid}>
  <HistoryPage {apiPrefix} {pagePrefix} />
</PublicPageShell>
