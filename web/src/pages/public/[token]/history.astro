---
import PublicLayout from '../../../components/layout/PublicLayout.astro';
import PublicInvalid from '../../../components/public/PublicInvalid.astro';
import HistoryList from '../../../components/history/HistoryList.svelte';
import { publicShareContext } from '../../../lib/public-share';

const { token = '' } = Astro.params;
const { apiPrefix, pagePrefix, valid } = await publicShareContext(Astro.request, token);
---

<PublicLayout title="Shared history · Spotrak" token={token} guard={valid}>
  {valid ? (
    <section class="page-stack">
      <div class="page-title">
        <h1>History</h1>
      </div>
      <HistoryList limit={50} apiPrefix={apiPrefix} pagePrefix={pagePrefix} client:visible />
    </section>
  ) : <PublicInvalid />}
</PublicLayout>
