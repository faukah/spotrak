---
import PublicLayout from '../../../../components/layout/PublicLayout.astro';
import PublicInvalid from '../../../../components/public/PublicInvalid.astro';
import CatalogDetail from '../../../../components/cards/CatalogDetail.svelte';
import type { TrackDetail } from '../../../../lib/api/types';
import { publicDetailContext } from '../../../../lib/public-share';
import { viewTransitionName } from '../../../../lib/images';

const { token = '', id = '' } = Astro.params;
const transitionName = Astro.url.searchParams.get('vt') ?? viewTransitionName(id);
const { apiPrefix, valid, initialDetail } = await publicDetailContext<TrackDetail>(Astro.request, token, `/tracks/${id}`);
---

<PublicLayout title="Shared track · Spotrak" token={token} guard={valid}>
  {valid ? <CatalogDetail kind="track" id={id} apiPrefix={apiPrefix} initialDetail={initialDetail} transitionName={transitionName} client:load /> : <PublicInvalid />}
</PublicLayout>
