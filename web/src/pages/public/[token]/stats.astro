---
import PublicPageShell from '../../../components/pages/PublicPageShell.astro';
import StatsPage from '../../../components/pages/StatsPage.astro';
import { serverApiFetch } from '../../../lib/api/server';
import type { StatsDashboardBootstrapResponse } from '../../../lib/api/types';
import { publicShareContext } from '../../../lib/public-share';
import { dashboardQuery, statsRangeFromCookie } from '../../../lib/stats-page';
import { STATS_RANGE_COOKIE_NAME } from '../../../lib/stores/stats-range';

const { token = '' } = Astro.params;
const { apiPrefix, pagePrefix, valid } = await publicShareContext(Astro.request, token);
const rangeCookie = Astro.cookies.get(STATS_RANGE_COOKIE_NAME)?.value ?? null;
const initialRange = statsRangeFromCookie(rangeCookie);
const initialBootstrap = valid
  ? await serverApiFetch<StatsDashboardBootstrapResponse>(
    Astro.request,
    `${apiPrefix}/stats/dashboard/bootstrap?${dashboardQuery(initialRange)}`,
  )
  : null;
---

<PublicPageShell title="Shared stats · Spotrak" {token} {valid}>
  <StatsPage {apiPrefix} {pagePrefix} {initialBootstrap} {initialRange} />
</PublicPageShell>
