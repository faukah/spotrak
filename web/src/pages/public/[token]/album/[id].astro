---
import CatalogDetailPage from '../../../../components/pages/CatalogDetailPage.astro';
import PublicPageShell from '../../../../components/pages/PublicPageShell.astro';
import type { AlbumDetail } from '../../../../lib/api/types';
import { publicDetailContext } from '../../../../lib/public-share';
const { token = '', id = '' } = Astro.params;
const transitionName = Astro.url.searchParams.get('vt') ?? undefined;
const { apiPrefix, valid, initialDetail } = await publicDetailContext<AlbumDetail>(Astro.request, token, `/albums/${id}`);
---

<PublicPageShell title="Shared album · Spotrak" {token} {valid}>
  <CatalogDetailPage kind="album" {id} {apiPrefix} {initialDetail} {transitionName} />
</PublicPageShell>
