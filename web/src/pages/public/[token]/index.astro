---
import OverviewPage from '../../../components/pages/OverviewPage.astro';
import PublicPageShell from '../../../components/pages/PublicPageShell.astro';
import { serverApiFetch } from '../../../lib/api/server';
import type { OverviewStatsResponse } from '../../../lib/api/types';
import { publicShareContext } from '../../../lib/public-share';
import { overviewQuery, statsRangeFromCookie } from '../../../lib/stats-page';
import { STATS_RANGE_COOKIE_NAME } from '../../../lib/stores/stats-range';

const { token = '' } = Astro.params;
const { apiPrefix, pagePrefix, valid } = await publicShareContext(Astro.request, token);
const rangeCookie = Astro.cookies.get(STATS_RANGE_COOKIE_NAME)?.value ?? null;
const initialRange = statsRangeFromCookie(rangeCookie);
const initialOverview = valid
  ? await serverApiFetch<OverviewStatsResponse>(
    Astro.request,
    `${apiPrefix}/stats/overview?${overviewQuery(initialRange)}`,
  )
  : null;
---

<PublicPageShell title="Shared overview · Spotrak" {token} {valid}>
  <OverviewPage {apiPrefix} {pagePrefix} {initialOverview} />
</PublicPageShell>
