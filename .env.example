DATABASE_URL=postgresql://spotrak:spotrak@127.0.0.1:5432/spotrak
API_ENDPOINT=http://127.0.0.1:8080
CLIENT_ENDPOINT=http://127.0.0.1:4322
SPOTIFY_PUBLIC=spotrak_client_id
SPOTIFY_SECRET=spotrak_client_secret
# Separate secret used to encrypt persisted Spotify access/refresh tokens.
# Generate with: openssl rand -base64 32
SPOTIFY_TOKEN_ENCRYPTION_KEY=replace_with_random_32_byte_secret
# Optional market for Spotify metadata requests.
# User-token requests still use this as an explicit market when configured.
SPOTIFY_MARKET=US
PORT=8080
TIMEZONE=UTC
LOG_LEVEL=debug
COOKIE_VALIDITY_MS=2592000000
# Minimum delay between Spotify requests. Values below 5000 are clamped to 5000.
SPOTIFY_API_DELAY_MS=5000
CORS=http://127.0.0.1:4322,http://localhost:4322
IMPORT_DIR=./imports
MAX_IMPORT_CACHE_SIZE=536870912
